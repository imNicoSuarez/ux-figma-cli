#!/bin/bash

# uxclaude — Launch UX Claude + Claude Code
# Connects to Figma via Safe Mode (plugin-based), then launches Claude Code.
#
# Usage:
#   uxclaude          → Connect and launch Claude Code
#   uxclaude --here   → Stay in current directory (don't cd to repo)
#   uxclaude --setup  → set/change the uxclaude repo path

CONFIG_DIR="$HOME/.uxclaude"
CONFIG_FILE="$CONFIG_DIR/config.json"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Config helpers ──

get_daemon_token() {
    local token_file="$HOME/.uxclaude/.daemon-token"
    if [ -f "$token_file" ]; then
        cat "$token_file" 2>/dev/null
    fi
}

get_repo_path() {
    if [ -f "$CONFIG_FILE" ]; then
        python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('repoPath',''))" 2>/dev/null
    fi
}

save_repo_path() {
    mkdir -p "$CONFIG_DIR"
    python3 -c "
import json, os
path = '$CONFIG_FILE'
cfg = {}
if os.path.exists(path):
    with open(path) as f: cfg = json.load(f)
cfg['repoPath'] = '$1'
with open(path, 'w') as f: json.dump(cfg, f, indent=2)
"
}

# ── Arrow-key selector (same UX as fancoolo-start) ──

select_file() {
    local options=("$@")
    local count=${#options[@]}
    local selected=0

    tput civis > /dev/tty 2>/dev/null
    trap 'tput cnorm > /dev/tty 2>/dev/null' EXIT

    draw_menu() {
        if [ "$1" = "redraw" ]; then
            printf "\033[%dA" "$((count + 2))" > /dev/tty
        fi

        printf "${BOLD}Select a Figma file (↑↓ arrows, Enter to confirm):${NC}\n" > /dev/tty
        printf "\n" > /dev/tty
        for i in "${!options[@]}"; do
            if [ "$i" -eq "$selected" ]; then
                printf "  ${GREEN}▸ %s${NC}\n" "${options[$i]}" > /dev/tty
            else
                printf "    %s\n" "${options[$i]}" > /dev/tty
            fi
        done
    }

    draw_menu "first"

    while true; do
        IFS= read -rsn1 key < /dev/tty

        case "$key" in
            $'\x1b')
                read -rsn2 seq < /dev/tty
                case "$seq" in
                    '[A')
                        ((selected--))
                        [ "$selected" -lt 0 ] && selected=$((count - 1))
                        ;;
                    '[B')
                        ((selected++))
                        [ "$selected" -ge "$count" ] && selected=0
                        ;;
                esac
                ;;
            ''|$'\n'|$'\r')
                tput cnorm > /dev/tty 2>/dev/null
                printf "\n" > /dev/tty
                printf '%s' "${options[$selected]}"
                return
                ;;
            'q')
                tput cnorm > /dev/tty 2>/dev/null
                printf "\n" > /dev/tty
                return
                ;;
        esac

        draw_menu "redraw"
    done
}

# ── Main ──

# Handle flags
STAY_HERE=false

for arg in "$@"; do
    case "$arg" in
        --here) STAY_HERE=true ;;
    esac
done

if [ "$1" = "--setup" ]; then
    printf "${BOLD}Enter the path to your uxclaude repo:${NC} "
    read -r repo_path < /dev/tty
    repo_path="${repo_path/#\~/$HOME}"
    if [ ! -f "$repo_path/src/index.js" ]; then
        echo -e "${RED}Not a valid uxclaude repo:${NC} $repo_path"
        exit 1
    fi
    save_repo_path "$repo_path"
    echo -e "${GREEN}Saved.${NC} Run ${BOLD}uxclaude${NC} to begin."
    exit 0
fi

# Resolve repo path
REPO_PATH=$(get_repo_path)

if [ -z "$REPO_PATH" ] || [ ! -d "$REPO_PATH" ]; then
    # Try to find it relative to this script
    SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
    if [ -f "$SCRIPT_DIR/src/index.js" ]; then
        REPO_PATH="$SCRIPT_DIR"
        save_repo_path "$REPO_PATH"
    else
        echo -e "${YELLOW}uxclaude repo not configured.${NC}"
        printf "${BOLD}Enter the path to your uxclaude repo:${NC} "
        read -r REPO_PATH < /dev/tty
        REPO_PATH="${REPO_PATH/#\~/$HOME}"
        if [ ! -f "$REPO_PATH/src/index.js" ]; then
            echo -e "${RED}Not a valid uxclaude repo:${NC} $REPO_PATH"
            exit 1
        fi
        save_repo_path "$REPO_PATH"
    fi
fi

CLI="$REPO_PATH/src/index.js"

echo ""
echo -e "${BOLD}  uxclaude${NC} ${DIM}— UX Claude launcher${NC}"
echo ""

# Step 1: Check if Figma is running, start if not
if ! pgrep -x "Figma" > /dev/null 2>&1; then
    echo -e "  ${YELLOW}Starting Figma...${NC}"
    open -a Figma
    sleep 3
fi

# Step 2: Connect via Safe Mode (plugin-based, no patching)
node "$CLI" connect --safe
if [ $? -ne 0 ]; then
    echo -e "  ${RED}Falló la conexión.${NC}"
    exit 1
fi
echo ""

# Step 3: Launch Claude Code
echo -e "  ${GREEN}Iniciando Claude Code...${NC}"
echo ""
if [ "$STAY_HERE" = false ]; then
    cd "$REPO_PATH" || exit 1
fi
exec claude
